{
  "Database": {
    "ConnectionString": ""
  },
  "Authentication": {
    "Google": {
      "ClientId": ""
    },
    "Jwt": {
      "Issuer": "",
      "Audience": "",
      "PlatformAudience": "",
      "SigningKey": "",
      "AccessTokenExpirationMinutes": 15,
      "RefreshTokenExpirationDays": 14
    },
    "PasswordReset": {
      "FrontendResetUrl": "http://localhost:3000/reset-password",
      "TokenLifetimeMinutes": 15,
      "RequestCooldownMinutes": 2
    }
  },
  "Caching": {
    "FieldPermissions": {
      "Mode": "MemoryOnly",
      "EntryTtlMinutes": 10
    }
  },
  "Companies": {
    "Ownership": {
      "MaxOwnedActiveCompanies": 2
    }
  },
  "BlobStorage": {
    "ConnectionString": "",
    "AccountName": "",
    "ProfileImagesContainer": "clarihr-profile-images",
    "PersonnelDocumentsContainer": "clarihr-personnel-documents",
    "ReportExportsContainer": "clarihr-report-exports",
    "ProfileImageSasTtlMinutes": 15,
    "PersonnelDocumentSasTtlMinutes": 15,
    "ReportExportSasTtlMinutes": 15,
    "ReportExportRetentionHours": 24
  },
  "Storage": {
    "DefaultProvider": "AzureBlob",
    "AzureBlob": {
      "AccountName": "",
      "BlobEndpoint": "",
      "DefaultContainer": "clarihr-files",
      "UploadUrlExpirationMinutes": 10,
      "ReadUrlExpirationMinutes": 15,
      "UseManagedIdentity": true
    },
    "Purposes": {
      "ProfileImage": {
        "MaxSizeBytes": 5242880,
        "AllowedContentTypes": [ "image/jpeg", "image/png", "image/webp" ],
        "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-profile-images"
      },
      "PersonnelDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png", "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".docx" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-personnel-documents"
      }
    },
    "Cleanup": {
      "IntervalMinutes": 30,
      "BatchSize": 100,
      "RetentionHours": 24
    }
  },
  "Reporting": {
    "Performance": {
      "MaxSynchronousExportRows": 5000,
      "MaxAsyncExportRows": 100000,
      "ExportBatchSize": 1000,
      "WorkerBatchSize": 2,
      "WorkerPollIntervalSeconds": 15,
      "ClaimLeaseMinutes": 15,
      "MaxAttempts": 3,
      "ArtifactRetentionHours": 24,
      "MaxDiagramNodes": 5000
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Swagger": {
    "Enabled": true
  },
  "AllowedHosts": "*"
}
