{
  "Database": {
    "ConnectionString": ""
  },
  "Authentication": {
    "Google": {
      "ClientId": ""
    },
    "Jwt": {
      "Issuer": "",
      "Audience": "",
      "PlatformAudience": "",
      "SigningKey": "",
      "AccessTokenExpirationMinutes": 15,
      "RefreshTokenExpirationDays": 14
    },
    "PasswordReset": {
      "FrontendResetUrl": "http://localhost:3000/reset-password",
      "TokenLifetimeMinutes": 15,
      "RequestCooldownMinutes": 2
    },
    "EmailVerification": {
      "FrontendVerifyUrl": "http://localhost:3000/verify-email",
      "TokenLifetimeMinutes": 60,
      "RequestCooldownMinutes": 2
    },
    "LoginThrottle": {
      "MaxFailedAttempts": 10,
      "WindowMinutes": 15,
      "LockoutMinutes": 15
    }
  },
  "Caching": {
    "FieldPermissions": {
      "Mode": "MemoryOnly",
      "EntryTtlMinutes": 10
    }
  },
  "Companies": {
    "Ownership": {
      "MaxOwnedActiveCompanies": 2
    }
  },

  "Storage": {
    "DefaultProvider": "AzureBlob",
    "AzureBlob": {
      "AccountName": "",
      "BlobEndpoint": "",
      "DefaultContainer": "clarihr-files",
      "UploadUrlExpirationMinutes": 10,
      "ReadUrlExpirationMinutes": 15,
      "UseManagedIdentity": true
    },
    "Purposes": {
      "ProfileImage": {
        "MaxSizeBytes": 5242880,
        "AllowedContentTypes": [ "image/jpeg", "image/png", "image/webp" ],
        "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-profile-images"
      },
      "PersonnelDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png", "application/vnd.openxmlformats-officedocument.wordprocessingml.document" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".docx" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-personnel-documents"
      },
      "ReportExport": {
        "MaxSizeBytes": 104857600,
        "AllowedContentTypes": [ "application/pdf", "text/csv", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" ],
        "AllowedExtensions": [ ".pdf", ".csv", ".xlsx" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-report-exports"
      },
      "CompanyLogo": {
        "MaxSizeBytes": 5242880,
        "AllowedContentTypes": [ "image/png", "image/jpeg", "image/webp" ],
        "AllowedExtensions": [ ".png", ".jpg", ".jpeg", ".webp" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-company-logos"
      },
      "MedicalClaimDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-medical-claim-documents"
      },
      "OffPayrollTransactionDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-off-payroll-transaction-documents"
      },
      "EconomicAidRequestDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-economic-aid-request-documents"
      },
      "CertificateRequestDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-certificate-request-documents"
      },
      "IncapacityDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-incapacity-documents"
      },
      "CompensatoryTimeDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf" ],
        "AllowedExtensions": [ ".pdf" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-compensatory-time-documents"
      },
      "RecognitionDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-recognition-documents"
      },
      "DisciplinaryActionDocument": {
        "MaxSizeBytes": 10485760,
        "AllowedContentTypes": [ "application/pdf", "image/jpeg", "image/png" ],
        "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ],
        "DefaultProvider": "AzureBlob",
        "RequiresMalwareScan": false,
        "ContainerOverride": "clarihr-disciplinary-action-documents"
      }
    },
    "Cleanup": {
      "IntervalMinutes": 30,
      "BatchSize": 100,
      "RetentionHours": 24
    }
  },
  "Reporting": {
    "Performance": {
      "MaxSynchronousExportRows": 5000,
      "MaxAsyncExportRows": 100000,
      "ExportBatchSize": 1000,
      "WorkerBatchSize": 2,
      "WorkerPollIntervalSeconds": 15,
      "ClaimLeaseMinutes": 15,
      "MaxAttempts": 3,
      "ArtifactRetentionHours": 24,
      "MaxDiagramNodes": 5000,
      "MaxDocumentBytes": 52428800
    },
    "Pdf": {
      "Engine": "Gotenberg",
      "Gotenberg": {
        "BaseUrl": "http://localhost:3000",
        "TimeoutSeconds": 60
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Swagger": {
    "Enabled": true
  },
  "AllowedHosts": "*"
}
