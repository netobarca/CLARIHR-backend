    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Local User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', data.accessToken || '');",
                  "  pm.collectionVariables.set('refreshToken', data.refreshToken || '');",
                  "  pm.collectionVariables.set('currentUserId', data.user?.id || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"Local\",\n  \"email\": \"admin@clarihr.test\",\n  \"password\": \"StrongPass123!\",\n  \"companyName\": \"Acme Local\",\n  \"country\": \"SV\",\n  \"source\": \"postman\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
