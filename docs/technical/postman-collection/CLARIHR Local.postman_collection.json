                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  const first = data.items && data.items.length > 0 ? data.items[0] : null;",
                  "  if (first && first.id) {",
                  "    pm.collectionVariables.set('auditLogId', first.id);",
                  "  }",
                  "}"
                ]
              }
            }
